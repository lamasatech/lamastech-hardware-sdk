<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Toggle LEDs -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toggle LEDs"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnBlueOn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Blue On"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnBlueOff"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Blue Off"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRedOn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Red On"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnRedOff"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Red Off"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnWhiteOn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="White On"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btnWhiteOff"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="White Off"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="12dp" />

        <!-- Direct Light Controls -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Direct Light Controls"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnTurnOnGreen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Turn On Green" />

        <Button
            android:id="@+id/btnTurnOnRed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Turn On Red" />

        <Button
            android:id="@+id/btnTurnOnWhite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Turn On White" />

        <Button
            android:id="@+id/btnTurnOffAll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Turn Off All Lights" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="12dp" />

        <!-- Support Queries -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Support Queries"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnIsSupportBlue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Is Support Blue?" />

        <Button
            android:id="@+id/btnIsSupportRed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Is Support Red?" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="12dp" />

        <!-- Result -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
