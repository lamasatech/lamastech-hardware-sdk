<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Firmware Update -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Firmware Update"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etFirmwarePath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Firmware file path (e.g. /sdcard/update.zip)"
            android:inputType="text" />

        <Button
            android:id="@+id/btnUpdateFirmware"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Update Firmware" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="12dp" />

        <!-- Timezone -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Timezone"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etTimezone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Asia/Riyadh"
            android:inputType="text" />

        <Button
            android:id="@+id/btnSetTimezone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set Timezone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="12dp" />

        <!-- NTP Server -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NTP Server"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnGetNtp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Get NTP Server" />

        <EditText
            android:id="@+id/etNtpUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="pool.ntp.org"
            android:inputType="text" />

        <Button
            android:id="@+id/btnSetNtp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set NTP Server" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="12dp" />

        <!-- Volume -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Volume"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/seekVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="15"
            android:progress="7" />

        <Button
            android:id="@+id/btnSetVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set Volume" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginVertical="12dp" />

        <!-- Result -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="12dp"
            android:background="#F5F5F5"
            android:text="Result will appear here"
            android:textIsSelectable="true" />

    </LinearLayout>
</ScrollView>
