<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F0F2F5">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RFID Reader"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="20dp" />

    <!-- Settings card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:elevation="2dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_serial_port"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/spinner_port"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_baud_rate">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/spinner_baud"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- Detection hint -->
    <TextView
        android:id="@+id/tv_port_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:layout_marginBottom="12dp"
        android:background="#E3F2FD"
        android:textSize="12sp"
        android:textColor="#1565C0"
        android:fontFamily="monospace"
        android:visibility="gone" />

    <!-- Start button — full width, colour reflects state -->
    <Button
        android:id="@+id/btn_start"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/btn_start"
        android:textSize="15sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="@color/btn_idle"
        android:layout_marginBottom="24dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DCDCDC"
        android:layout_marginBottom="16dp" />

    <!-- Last scan label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_last_scan"
        android:textSize="11sp"
        android:textColor="#9E9E9E"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp" />

    <!-- UID display + clear button inline -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tv_last_uid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/waiting"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:padding="16dp"
            android:singleLine="true"
            android:ellipsize="end" />

        <ImageButton
            android:id="@+id/btn_clear"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_clear"
            android:scaleType="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_clear"
            android:layout_marginEnd="4dp" />

    </LinearLayout>

</LinearLayout>
