<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RFID Sample"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="24dp" />

    <!-- Serial port path -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_serial_port"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinner_port"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:layout_marginBottom="16dp" />

    <!-- Baud rate -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_baud_rate"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinner_baud"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tv_port_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:layout_marginBottom="16dp"
        android:background="#E3F2FD"
        android:textSize="12sp"
        android:textColor="#1565C0"
        android:fontFamily="monospace"
        android:visibility="gone" />

    <Button
        android:id="@+id/btn_start"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_start"
        android:textSize="14sp"
        android:layout_marginBottom="32dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_last_scan"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_last_uid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/waiting"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_clear"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_clear"
        android:textSize="12sp"
        style="@style/Widget.AppCompat.Button.Borderless"
        android:layout_gravity="end" />

</LinearLayout>
